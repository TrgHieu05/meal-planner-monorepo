# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=meal_planner
POSTGRES_PORT=5432

# Backend Configuration
PORT=3000

# DATABASE_URL cho Local Development (Prisma Client chạy trên máy host kết nối tới Docker)
# Lưu ý: Khi chạy trong Docker container, service 'main-backend' sẽ dùng host 'postgres' (được override trong docker-compose)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/meal_planner?schema=public"

EXPO_PUBLIC_API_BASE_URL=

# Google OAuth2 Configuration
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

JWT_SECRET=
JWT_EXPIRES_IN=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Public Domains
MAIN_DOMAIN=
API_PRODUCTION_DOMAIN=
API_STAGING_DOMAIN=
