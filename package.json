{
  "name": "meal-planner-monorepo",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev:backend": "pnpm run build:shared && pnpm --filter main-backend start:dev",
    "dev:mobile": "pnpm --filter mobile-app start",
    "dev:web": "pnpm --filter mobile-app web",
    "build:shared": "pnpm --filter @meal/shared run build",
    "build:backend": "pnpm run build:shared && pnpm --filter main-backend run build",
    "infra:up": "docker-compose --env-file .env -p meal-planner-monorepo -f infrastructure/docker-compose.yml up -d --build",
    "infra:down": "docker-compose --env-file .env -p meal-planner-monorepo -f infrastructure/docker-compose.yml down",
    "db:up": "docker-compose --env-file .env -p meal-planner-monorepo -f infrastructure/docker-compose.yml up -d postgres",
    "db:stop": "docker-compose --env-file .env -p meal-planner-monorepo -f infrastructure/docker-compose.yml stop postgres",
    "prisma:generate": "pnpm --filter @meal/database exec prisma generate",
    "prisma:migrate": "pnpm --filter @meal/database exec prisma migrate dev",
    "prisma:reset": "pnpm --filter @meal/database exec prisma migrate reset",
    "prisma:studio": "pnpm --filter @meal/database exec prisma studio",
    "test:backend": "pnpm --filter main-backend run test && pnpm --filter main-backend run test:e2e"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.3",
  "dependencies": {
    "@types/node": "^25.3.5",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "react-test-renderer": "19.2.0"
    },
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "@scarf/scarf",
      "prisma",
      "unrs-resolver"
    ]
  }
}
