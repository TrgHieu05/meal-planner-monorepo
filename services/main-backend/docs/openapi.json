                    "id": "63914c9d-3f89-4a60-a67d-be0d29b5e623",
                    "email": "quytvo2626@gmail.com",
                    "userName": "quý võ"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Token không hợp lệ hoặc đã hết hạn"
          }
        },
        "security": [
          {
            "JWT": []
          }
        ],
        "summary": "Lấy thông tin profile user hiện tại",
        "tags": [
          "Authentication"
        ]
      }
    },
