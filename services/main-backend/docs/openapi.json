                  "portionSize": {
                    "type": "number",
                    "minimum": 0.01,
                    "example": 1.5
                  }
                },
                "additionalProperties": false
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Menu item created successfully."
