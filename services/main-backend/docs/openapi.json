      "description": "Nginx Gateway Local"
    },
    {
      "url": "http://localhost:3000",
      "description": "Direct Main-Backend Port"
    }
  ],
  "components": {
    "securitySchemes": {
      "JWT": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http",
        "name": "Authorization",
        "description": "Nhập JWT token (không cần tiền tố Bearer)",
        "in": "header"
      }
    },
    "schemas": {}
  }
